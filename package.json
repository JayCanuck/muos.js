{
  "name": "muos",
  "version": "1.1.2",
  "description": "Javascript/Typescript definitions and helper functions for muOS",
  "type": "module",
  "main": "./dist/muos.cjs",
  "module": "./dist/muos.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/muos.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/muos.cjs"
      }
    }
  },
  "author": "Jason Robitaille",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/jaycanuck/muos.js/issues"
  },
  "homepage": "https://github.com/jaycanuck/muos.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaycanuck/muos.js.git"
  },
  "scripts": {
    "update": "tsx scripts/update.ts",
    "bump": "tsx scripts/bump.ts",
    "build": "vite build",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "quoteProps": "preserve",
    "trailingComma": "none",
    "arrowParens": "avoid"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.12.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
